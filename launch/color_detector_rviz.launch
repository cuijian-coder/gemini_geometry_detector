<launch>
  <!--
    Launch color region detector together with RViz.
    Use this when the camera driver (or bag) is already publishing RGB and CameraInfo.
  -->

  <arg name="input_topic" default="/camera/color/image_raw"/>
  <arg name="camera_info_topic" default="/camera/color/camera_info"/>
  <arg name="config_file"
       default="$(find gemini_geometry_detector)/config/detector.yaml"/>
  <arg name="rviz_config"
       default="$(find gemini_geometry_detector)/rviz/color_detector.rviz"/>
  <arg name="ground_plane_provider_type" default=""/>
  <arg name="camera_height" default=""/>

  <!-- Color region detector -->
  <include file="$(find gemini_geometry_detector)/launch/color_detector.launch">
    <arg name="input_topic" value="$(arg input_topic)"/>
    <arg name="camera_info_topic" value="$(arg camera_info_topic)"/>
    <arg name="config_file" value="$(arg config_file)"/>
    <arg name="ground_plane_provider_type" value="$(arg ground_plane_provider_type)"/>
    <arg name="camera_height" value="$(arg camera_height)"/>
  </include>

  <!-- RViz -->
  <node name="color_detector_rviz" pkg="rviz" type="rviz"
        args="-d $(arg rviz_config)"/>
</launch>
